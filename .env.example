# Copy to .env for local development. In prod, k3s ConfigMap/Secret injects these.

APP_ENV=dev
LOG_LEVEL=INFO

# PostgreSQL (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aidd_user
POSTGRES_PASSWORD=aidd_password
POSTGRES_DB=aidd_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# SeaweedFS S3
S3_ENDPOINT_URL=http://localhost:8333
S3_ACCESS_KEY=any
S3_SECRET_KEY=any
S3_REGION=us-east-1
S3_BUCKET=aidd-data

# Auth
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# LLM
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
QWEN_BASE_URL=
QWEN_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
QWEN_API_KEY=EMPTY

# LLM fallback: when Gemini returns 503 / 429 / UNAVAILABLE, automatically
# fall back to local Qwen vLLM. Once tripped, the breaker stays open for
# LLM_CIRCUIT_BREAK_SECONDS before the next probe to Gemini.
LLM_FALLBACK_ENABLED=true
LLM_CIRCUIT_BREAK_SECONDS=300
